{
    "info":  {
                 "_postman_id":  "94d7c1b7-0c23-4f8d-ae37-5d3f0e31e1db",
                 "name":  "Upload APIs",
                 "description":  "Teamoria AI Service endpoints for backend integration. Set `internal_api_key` to the same value as `INTERNAL_API_KEY` in `ai-service/.env`.",
                 "schema":  "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
             },
    "variable":  [
                     {
                         "key":  "base_url",
                         "value":  "http://127.0.0.1:8001"
                     },
                     {
                         "key":  "api_prefix",
                         "value":  "/api/v1"
                     },
                     {
                         "key":  "internal_api_key",
                         "value":  "change_me",
                         "type":  "secret"
                     },
                     {
                         "key":  "project_id",
                         "value":  "project-1"
                     },
                     {
                         "key":  "upload_id",
                         "value":  "upload-1"
                     },
                     {
                         "key":  "user_id",
                         "value":  "system"
                     },
                     {
                         "key":  "user_role",
                         "value":  "admin"
                     }
                 ],
    "auth":  {
                 "type":  "apikey",
                 "apikey":  [
                                {
                                    "key":  "key",
                                    "value":  "X-Internal-API-Key",
                                    "type":  "string"
                                },
                                {
                                    "key":  "value",
                                    "value":  "{{internal_api_key}}",
                                    "type":  "string"
                                },
                                {
                                    "key":  "in",
                                    "value":  "header",
                                    "type":  "string"
                                }
                            ]
             },
    "event":  [
                  {
                      "listen":  "prerequest",
                      "script":  {
                                     "type":  "text/javascript",
                                     "exec":  [
                                                  "pm.request.headers.upsert({ key: \u0027X-Internal-API-Key\u0027, value: pm.variables.get(\u0027internal_api_key\u0027) || \u0027\u0027 });",
                                                  "pm.request.headers.upsert({ key: \u0027X-User-Id\u0027, value: pm.variables.get(\u0027user_id\u0027) || \u0027system\u0027 });",
                                                  "pm.request.headers.upsert({ key: \u0027X-User-Role\u0027, value: pm.variables.get(\u0027user_role\u0027) || \u0027admin\u0027 });"
                                              ]
                                 }
                  }
              ],
