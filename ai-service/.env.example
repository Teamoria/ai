# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/teamoria_ai
#
# MySQL example. URL-encode special password characters, e.g. @ becomes %40.
DATABASE_URL=mysql+pymysql://db_user:db_password@db_host:3306/db_name?charset=utf8mb4
#
# Optional DB_* fallback when DATABASE_URL is not set:
# DB_CONNECTION=mysql
# DB_HOST=db_host
# DB_PORT=3306
# DB_DATABASE=db_name
# DB_USERNAME=db_user
# DB_PASSWORD=db_password
INTERNAL_API_KEY=change_me
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_VERIFY_SSL=true
GROQ_REQUEST_TIMEOUT=90
FFMPEG_PATH=ffmpeg
MEDIA_CHUNK_SECONDS=300
UPLOAD_TEMP_DIR=tmp/uploads
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
# Optional aliases supported by the service:
PINECONE_INDEX=
PINECONE_HOST=
PINECONE_NAMESPACE=
PINECONE_NAMESPACE_PREFIX=teamoria
EMBEDDING_DIMENSIONS=1024
