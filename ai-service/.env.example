# Teamoria AI Service
# Copy this file to ai-service/.env and replace every placeholder.
# Never commit ai-service/.env.

# ── Application ────────────────────────────────────
APP_NAME=Teamoria AI Service
INTERNAL_API_KEY=replace_with_a_long_random_secret
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Loaded by: docker compose --env-file ai-service/.env ...
# This is the host port; the container always listens on port 8000.
# Keep AI on 8001 when Laravel/PHP uses 8000 on the same server.
AI_SERVICE_PORT=8001

# ── Database ───────────────────────────────────────
# Used when running FastAPI directly on the host.
# Docker Compose overrides this value with its internal PostgreSQL connection.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/teamoria_ai

# To use the same MySQL database as Laravel, replace DATABASE_URL with:
# DATABASE_URL=mysql+pymysql://db_user:db_password@db_host:3306/db_name?charset=utf8mb4
# URL-encode special characters in URL credentials, e.g. @ becomes %40.

# Alternatively, leave DATABASE_URL empty and configure DB_* variables.
# Credentials supplied this way are URL-encoded automatically.
# DATABASE_URL=
# DB_CONNECTION=mysql
# DB_HOST=db_host
# DB_PORT=3306
# DB_DATABASE=db_name
# DB_USERNAME=db_user
# DB_PASSWORD=db_password

# ── Language and transcription models ──────────────
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_TRANSCRIPTION_LANGUAGE=
GROQ_VERIFY_SSL=true
GROQ_REQUEST_TIMEOUT=90

# Reserved for OpenAI-backed features.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# ── Media and uploads ──────────────────────────────
FFMPEG_PATH=ffmpeg
MEDIA_CHUNK_SECONDS=300
UPLOAD_TEMP_DIR=tmp/uploads
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_TESSDATA_DIR=tessdata

# Optional headers used when AI downloads Laravel-owned files through file_url.
# Leave empty if Laravel provides a signed public/internal URL.
BACKEND_FILE_API_KEY=
BACKEND_FILE_API_KEY_HEADER=x-api-key
BACKEND_FILE_BEARER_TOKEN=

# ── Pinecone and embeddings ────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE_PREFIX=teamoria
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1024

# Optional Pinecone overrides/aliases:
# PINECONE_INDEX=
# PINECONE_HOST=
# PINECONE_NAMESPACE=
